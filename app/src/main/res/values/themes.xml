<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MotionWall" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">#0B0B0E</item>
        <item name="android:navigationBarColor">#0B0B0E</item>
        <item name="android:windowBackground">#0B0B0E</item>
    </style>

    <!-- Branded splash: Wally logo on its own navy, then hand off. -->
    <style name="Theme.MotionWall.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#030826</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/wally_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.MotionWall</item>
    </style>
</resources>
